# Your wallet private key (no 0x prefix)
PRIVATE_KEY=

# Infura project ID (used if SEPOLIA_RPC_URL is not set)
INFURA_API_KEY=

# Optional: override the RPC endpoint entirely
# SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Etherscan V2 API key — https://etherscan.io/myapikey
ETHERSCAN_API_KEY=
